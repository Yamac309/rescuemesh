VITE_API_BASE_URL=http://localhost:8000

# Optional: Google Maps browser key if you switch back to the Google Maps
# implementation on another branch.
VITE_GOOGLE_MAPS_API_KEY=

# Optional: Apple MapKit JS token. Without this, RescueMesh uses its improved
# satellite fallback map and still supports location search.
VITE_MAPKIT_JS_TOKEN=
