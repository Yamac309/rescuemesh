GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash-lite
GOOGLE_AI_TIMEOUT_SECONDS=30
GOOGLE_AI_THINKING_BUDGET=0
MONGODB_URI=
MONGODB_DATABASE=rescuemesh
MONGODB_LIVE_INCIDENTS_COLLECTION=live_incidents
MONGODB_TIMEOUT_MS=2500
LIVE_INCIDENTS_USER_AGENT=RescueMesh/0.1 live incident importer

# Security hardening for public deployments. Leave blank for local classroom demos.
RESCUEMESH_PUBLIC_MODE=false
RESCUEMESH_ADMIN_TOKEN=
RESCUEMESH_RESPONDER_TOKEN=
RESCUEMESH_CORS_ORIGINS=
RESCUEMESH_CORS_ORIGIN_REGEX=
RESCUEMESH_REQUIRE_HTTPS=false
RESCUEMESH_DISABLE_RATE_LIMITING=false
